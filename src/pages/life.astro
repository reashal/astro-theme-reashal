---
/**
 * 随笔页面
 * 展示所有随笔文章
 */
import "../styles/docs.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleList from "../components/ArticleList.astro";
import { processArticles } from "../utils/articles";
import { PAGE_CONFIG } from "../consts/pages";

// 获取文章数据（必须使用字面量字符串）
const lifeArticles = await Astro.glob("../pages/life/*.md");

// 处理文章：分离置顶并排序
const displayArticles = processArticles(lifeArticles);

const pageTitle = PAGE_CONFIG.life.title;
const pageDescription = PAGE_CONFIG.life.description;
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
    <ArticleList articles={displayArticles} />
</BaseLayout>
