---
/**
 * 笔记页面
 * 展示所有笔记文章（包括 about 页面）
 */
import "../styles/docs.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleList from "../components/ArticleList.astro";
import { processArticles } from "../utils/articles";
import { PAGE_CONFIG } from "../consts/pages";

// 获取文章数据（必须使用字面量字符串）
const aboutArticles = await Astro.glob("../pages/about.md");
const docsArticles = await Astro.glob("../pages/docs/*.md");
const allArticles = [...aboutArticles, ...docsArticles];

// 处理文章：分离置顶并排序
const displayArticles = processArticles(allArticles);

const pageTitle = PAGE_CONFIG.docs.title;
const pageDescription = PAGE_CONFIG.docs.description;
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
    <ArticleList articles={displayArticles} />
</BaseLayout>
