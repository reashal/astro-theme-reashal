---
import "../styles/showcase.css";
import Giscus from "../components/Giscus.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import showcaseConfig from "../showcase.json";
import pagesConfig from "../pages-config.json";

const config = showcaseConfig.showcases.links;
const pageTitle = config.title;
const pageDescription = config.description;

// 获取所有 showcase 类型的页面用于导航
const showcasePages = pagesConfig.pages.filter(page => page.type === 'showcase');

// 辅助函数：获取首字母
const getInitial = (title: string) => title.charAt(0).toUpperCase();
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <article class="article-container showcase">
    {/* 顶部导航 */}
    {showcasePages.length > 1 && (
      <nav class="showcase-nav">
        {showcasePages.map(page => {
          const isActive = page.dataSource?.collectionKey === 'links';
          const href = page.path;
          return (
            <a href={href} class={isActive ? 'active' : ''}>
              <i class={page.icon}></i>
              <span>{page.title}</span>
            </a>
          );
        })}
      </nav>
    )}

    {config.intro && config.intro.length > 0 && (
      <>
        <h2 class="showcase-h showcase-intro">写在前面</h2>
        {config.intro.map((paragraph: string) => (
          <p class="showcase-p">{paragraph}</p>
        ))}
      </>
    )}
    
    {config.sections.map((section) => (
      <>
        <h2 class="showcase-h">
          {section.title}
        </h2>
        <div class="showcase-body">
          {section.cards.map((card) => (
            <a href={card.link} target="_blank" class={`showcase-${card.imageMode}`}>
              {(card.imageMode === 'icon-simple' || card.imageMode === 'app-card') && (
                <div class="showcase-avatar" data-initial={getInitial(card.title)}>
                  {card.image && (
                    <img
                      src={card.image}
                      alt={card.title}
                      title={card.title}
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none'"
                    />
                  )}
                </div>
              )}
              {card.imageMode === 'product-card' && (
                <div class="showcase-large-image" data-title={getInitial(card.title)}>
                  {card.image && (
                    <img
                      src={card.image}
                      alt={card.title}
                      title={card.title}
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none'"
                    />
                  )}
                </div>
              )}
              <div class="showcase-info">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </div>
            </a>
          ))}
        </div>
      </>
    ))}
    
    {(config as any).showFooter === true && (
      <section class="article-copy">
        <div>名称：睿屿青衫</div>
        <div>网址：https://www.reashal.com</div>
        <div>头像：https://www.reashal.com/static/images/reashal.svg</div>
        <div>描述：有限的文字无法写尽余生，希望我们能在前行的路上久别重逢。</div>
      </section>
    )}
    <Giscus />
  </article>
</BaseLayout>
