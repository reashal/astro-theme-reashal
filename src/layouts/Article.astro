---
import "../styles/md.css";
import "../styles/tags.css";
import Giscus from "../components/Giscus.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import type { ArticleFrontmatter } from "../types";
import BaseLayout from "./BaseLayout.astro";

interface Props {
    frontmatter: ArticleFrontmatter;
}

const { frontmatter } = Astro.props as Props;
const tags = frontmatter.tags || [];
---

<BaseLayout pageTitle={frontmatter.title} pageDescription={frontmatter.desc}>
    <ReadingProgress />
    <article
        class="article-container doc"
        data-pagefind-body
        data-pagefind-filter="section:docs"
    >
        <h1 class="article-search-meta" data-pagefind-meta="title">
            {frontmatter.title}
        </h1>
        <span
            class="article-search-meta"
            data-pagefind-meta="description"
            aria-hidden="true"
        >
            {frontmatter.desc}
        </span>
        <span
            class="article-search-meta"
            data-pagefind-meta="tags"
            aria-hidden="true"
        >
            {tags.join(" ")}
        </span>
        <slot />
        <section class="article-tags">
            {
                tags.map((tag) => (
                    <span class="tag" data-pagefind-filter="tag">{tag}</span>
                ))
            }
        </section>
        <section class="article-copy" data-pagefind-ignore="all">
            <div>
                本文作者：<a href={frontmatter.source} target="_blank" rel="noopener noreferrer"
                    >{frontmatter.author}</a
                >
            </div>
            <div>
                本文来源：<a href={frontmatter.source} target="_blank" rel="noopener noreferrer"
                    >{frontmatter.source}</a
                >
            </div>
            <div class="article-copy-info">
                许可协议：<a
                    href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans"
                    target="_blank"
                    rel="noopener noreferrer">CC BY-NC-SA 4.0</a
                >
            </div>
            <div class="article-copy-info">
                本站随笔均为原创，涉及隐私且时效性较强，不允许任何人以任何形式转载。
            </div>
            <div class="article-copy-info">
                本站笔记多对原始作品作出修改，允许非商业用途转载，转载时请注明出处。
            </div>
        </section>
        <Giscus />
    </article>
</BaseLayout>
