---
/**
 * 文章列表组件
 * 职责：
 * 1. 提供文章列表的容器和基础样式
 * 2. 实现分页功能（根据屏幕高度自动计算每页显示数量）
 * 3. 显示底部提示信息
 * 4. 渲染文章卡片（支持置顶文章）
 * 
 * 使用方式：
 * <ArticleList articles={articleArray} />
 */
import { SITE_INFO } from "../consts";
import "../styles/docs.css";

interface Props {
    articles: any[];
}

const { articles } = Astro.props;
---

<article class="article-container docs" id="docs-container">
    {articles.map((post, index) => {
        const isPinned = post.frontmatter.pinned === true;
        return (
            <div
                class={`docs-body ${isPinned ? "docs-fixed" : ""}`}
                data-article-index={index}
            >
                <a href={post.url} class="docs-a">
                    <h2 class="docs-h">{post.frontmatter.title}</h2>
                </a>
                <p class="docs-p">{post.frontmatter.desc}</p>
                <time class="docs-t">
                    {post.frontmatter.pubDate?.substr(0, 10)}
                </time>
            </div>
        );
    })}
    
    {articles.length === 0 && (
        <div class="docs-body">
            <p class="docs-p">暂无文章</p>
        </div>
    )}

    <footer class="docs-footer" id="docs-footer">
        <nav class="docs-pagination" id="docs-pagination" aria-label="分页导航">
        </nav>
        <p class="end-tip" id="docs-end-tip">{SITE_INFO.endTip}</p>
    </footer>
    <script>
        (function () {
            const container = document.getElementById("docs-container")!;
            const pagination = document.getElementById("docs-pagination")!;
            const footer = document.getElementById("docs-footer")!;
            const endTip = document.getElementById("docs-end-tip")!;
            
            const allItems = Array.from(
                container.querySelectorAll(".docs-body"),
            ) as HTMLElement[];
            if (allItems.length === 0) return;

            let currentPage = 0;
            let perPage = 1;
            let hasEnoughSpace = false;

            function calcPerPage(): number {
                const rootStyle = getComputedStyle(document.documentElement);
                const perPage = parseInt(rootStyle.getPropertyValue('--per-page')) || 1;
                return perPage;
            }

            function totalPages(): number {
                if (perPage <= 0) return 0;
                return Math.ceil(allItems.length / perPage);
            }

            function checkEnoughSpace(): void {
                const mainEl = document.querySelector(".main") as HTMLElement | null;
                if (!mainEl) {
                    hasEnoughSpace = false;
                    return;
                }
                
                const footerEl = document.getElementById("docs-footer") as HTMLElement | null;
                if (!footerEl) {
                    hasEnoughSpace = false;
                    return;
                }
                
                const viewportH = mainEl.clientHeight;
                const footerH = footerEl.offsetHeight;
                const articleStyle = getComputedStyle(container);
                const articlePaddingV =
                    parseFloat(articleStyle.paddingTop) +
                    parseFloat(articleStyle.paddingBottom);
                
                // 计算实际使用的空间
                let usedHeight = articlePaddingV;
                allItems.forEach(item => {
                    const itemStyle = getComputedStyle(item);
                    usedHeight += item.offsetHeight +
                        parseFloat(itemStyle.marginTop) +
                        parseFloat(itemStyle.marginBottom);
                });
                
                // 检查是否有足够的空间（至少 100px）
                const available = viewportH - usedHeight - footerH;
                hasEnoughSpace = available > 100;
            }

            function showPage(page: number): void {
                currentPage = Math.max(0, Math.min(page, totalPages() - 1));
                const start = currentPage * perPage;
                const end = start + perPage;
                const isLastPage = currentPage === totalPages() - 1;

                // 检查空间
                checkEnoughSpace();
                
                // 只在所有文章都在一页展示完，并且底部有足够空间时显示"故事暂且讲到这里"
                endTip.style.display = (totalPages() === 1 && hasEnoughSpace) ? "" : "none";

                allItems.forEach((item, i) => {
                    const isVisible = i >= start && i < end;
                    item.style.display = isVisible ? "" : "none";
                    item.classList.toggle(
                        "docs-last",
                        isVisible && i === end - 1,
                    );
                });

                renderPagination();
            }

            function renderPagination(): void {
                const total = totalPages();
                if (total <= 1) {
                    pagination.style.display = "none";
                    return;
                }
                pagination.style.display = "";

                const pages: (number | string)[] = [];
                if (total <= 7) {
                    for (let i = 0; i < total; i++) pages.push(i);
                } else {
                    pages.push(0);
                    if (currentPage > 3) pages.push("…");
                    const lo = Math.max(1, currentPage - 1);
                    const hi = Math.min(total - 2, currentPage + 1);
                    for (let i = lo; i <= hi; i++) pages.push(i);
                    if (currentPage < total - 4) pages.push("…");
                    pages.push(total - 1);
                }

                pagination.innerHTML = "";

                const prev = document.createElement("button");
                prev.className = "page-btn page-prev";
                prev.textContent = "‹";
                prev.disabled = currentPage === 0;
                prev.addEventListener("click", () => {
                    showPage(currentPage - 1);
                    scrollToTop();
                });
                pagination.appendChild(prev);

                pages.forEach((p) => {
                    if (p === "…") {
                        const sep = document.createElement("span");
                        sep.className = "page-sep";
                        sep.textContent = "…";
                        pagination.appendChild(sep);
                    } else {
                        const btn = document.createElement("button");
                        btn.className =
                            "page-btn" +
                            (p === currentPage ? " page-active" : "");
                        btn.textContent = String(Number(p) + 1);
                        btn.addEventListener("click", () => {
                            showPage(Number(p));
                            scrollToTop();
                        });
                        pagination.appendChild(btn);
                    }
                });

                const next = document.createElement("button");
                next.className = "page-btn page-next";
                next.textContent = "›";
                next.disabled = currentPage === totalPages() - 1;
                next.addEventListener("click", () => {
                    showPage(currentPage + 1);
                    scrollToTop();
                });
                pagination.appendChild(next);
            }

            function scrollToTop(): void {
                const mainEl = document.querySelector(".main") as HTMLElement | null;
                if (mainEl) mainEl.scrollTo({ top: 0, behavior: "smooth" });
            }

            function init(): void {
                perPage = calcPerPage();
                checkEnoughSpace();
                showPage(0);
            }

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", init);
            } else {
                requestAnimationFrame(() => requestAnimationFrame(init));
            }

            let resizeTimer: number;
            window.addEventListener("resize", () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(() => {
                    const prevPage = currentPage;
                    perPage = calcPerPage();
                    checkEnoughSpace();
                    showPage(Math.min(prevPage, totalPages() - 1));
                }, 150);
            });
        })();
    </script>
</article>
