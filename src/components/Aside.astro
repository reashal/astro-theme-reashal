---
/**
 * 侧边栏组件
 * 
 * 包含模块：
 * 1. 站长信息卡片 (aside-author-card) - 显示头像、名称、简介
 * 2. 导航链接卡片 (aside-links-card) - 网站主要页面导航
 * 3. 分享按钮卡片 (aside-share-card) - 分享当前页面功能
 * 4. 标签云卡片 (aside-tags-card) - 显示所有文章标签
 * 5. 版权信息卡片 (aside-copyright-card) - 网站版权信息
 * 
 * 命名规范：
 * - 卡片类名统一使用 aside-{模块}-card 格式
 * - 卡片内部元素使用 {模块}-{元素} 格式，如 author-avatar、author-name
 */
import "../styles/aside.css";
import { AUTHOR_INFO } from "../consts";
import pagesConfigJson from "../pages-config.json";
import { pagesConfigSchema } from "../types";
import GetTags from "./GetTags.astro";

const pagesConfig = pagesConfigSchema.parse(pagesConfigJson);
const navLinks = pagesConfig.pages
    .filter(page => !page.hiddenInAside)
    .map(page => ({
        label: page.title,
        href: page.path,
        icon: page.icon,
        external: page.type === 'external'
    }));

const currentPath = Astro.url.pathname;
---

<aside>
    <section class="aside-body">
        <!-- 站长信息卡片：hover 时显示详细简介 -->
        <section class="aside-author-card">
            <img
                class="author-avatar"
                src={AUTHOR_INFO.avatar}
                alt={AUTHOR_INFO.name}
                title={AUTHOR_INFO.name}
                loading="lazy"
                decoding="async"
            />
            <div class="author-info">
                <h3 class="author-name">{AUTHOR_INFO.name}</h3>
                <p class="author-desc">{AUTHOR_INFO.description}</p>
            </div>
        </section>

        <!-- 导航链接卡片：2x2 网格布局 -->
        <section class="aside-links-card">
            {
                navLinks.map((link) => {
                    const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
                    return (
                        <a
                            href={link.href}
                            target={link.external ? "_blank" : "_self"}
                            rel={link.external ? "noopener noreferrer" : undefined}
                            class={`${link.icon} ${isActive ? 'active' : ''}`}
                        >
                            {link.label}
                        </a>
                    );
                })
            }
        </section>

        <!-- 分享按钮卡片 -->
        <section class="aside-share-card">
            <button type="button" class="share-link" id="aside-share-btn">
                <i class="iconfont icon-share"></i>
                分享当前页面
            </button>
        </section>

        <!-- 标签云卡片 -->
        <GetTags />

        <!-- 版权信息卡片 -->
        <section class="aside-copyright-card">
            <div>
                Powered By <a href="//astro.build" class="copy-a" target="_blank"
                    >Astro</a
                >
            </div>
            <div>
                Themed By <a href="/about" class="copy-a"
                    >reashal</a
                >
            </div>
        </section>
    </section>

    <!-- 侧边栏折叠/展开按钮 -->
    <button
        type="button"
        class="aside-toggle-btn"
        aria-label="展开侧边栏"
        aria-expanded="false"
    ></button>
</aside>

<script>
    const layout = document.querySelector("main");
    const mainContent = layout?.querySelector(".main");
    const asideToggle = document.querySelector(".aside-toggle-btn");
    const asideShareBtn = document.getElementById("aside-share-btn");

    function setAsideOpen(isOpen: boolean) {
        if (!layout) return;

        layout.classList.remove("aside-init", "aside-show", "aside-hide");
        layout.classList.add(isOpen ? "aside-show" : "aside-hide");

        if (asideToggle) {
            asideToggle.setAttribute("aria-expanded", String(isOpen));
            asideToggle.setAttribute(
                "aria-label",
                isOpen ? "收起侧边栏" : "展开侧边栏",
            );
        }
    }

    asideToggle?.addEventListener("click", () => {
        setAsideOpen(!layout?.classList.contains("aside-show"));
    });

    mainContent?.addEventListener("click", () => {
        if (layout?.classList.contains("aside-show")) {
            setAsideOpen(false);
        }
    });

    // 分享按钮点击事件：先折叠侧边栏，再弹出分享卡片
    if (asideShareBtn) {
        asideShareBtn.addEventListener("click", () => {
            const wasOpen = layout?.classList.contains("aside-show") ?? false;
            if (wasOpen) setAsideOpen(false);

            setTimeout(() => {
                document.getElementById("share-btn")?.click();
            }, wasOpen ? 300 : 0);
        });
    }
</script>
