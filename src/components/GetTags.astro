---
const docsModules = await import.meta.glob("../pages/docs/*.md", { eager: true });
const lifeModules = await import.meta.glob("../pages/life/*.md", { eager: true });
const allArticles = [...Object.values(docsModules), ...Object.values(lifeModules)] as unknown as Array<{
    frontmatter: { tags?: string[] };
}>;

const allTags = new Set<string>();
allArticles.forEach(post => {
    if (post.frontmatter.tags && post.frontmatter.tags.length > 0) {
        post.frontmatter.tags.forEach((tag: string) => allTags.add(tag));
    }
});

const tagCounts = new Map<string, number>();
allArticles.forEach(post => {
    if (post.frontmatter.tags) {
        post.frontmatter.tags.forEach((tag: string) => {
            tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
        });
    }
});

const sortedTags = Array.from(allTags).sort((a, b) => {
    const countA = tagCounts.get(a) || 0;
    const countB = tagCounts.get(b) || 0;
    return countB - countA;
});

const tagCountsObj = Object.fromEntries(tagCounts);
const cardList = sortedTags.map((tag) => ({ tag, count: tagCountsObj[tag] }));
---

<section class="aside-tags-card">
  <div class="card-stack" id="card-stack">
    {cardList.map((item) => (
      <a href={`/tags/${item.tag}`} class="message-card">
        <span class="msg-hashtag">#</span>
        <span class="msg-name">{item.tag}</span>
        <span class="msg-count">{item.count}</span>
      </a>
    ))}
  </div>
  <div class="stack-footer" id="stack-footer"></div>
</section>

<script>
(function() {
  const stack = document.getElementById('card-stack');
  const footer = document.getElementById('stack-footer');
  if (!stack) return;

  let cards = Array.from(stack.querySelectorAll('.message-card'));
  const total = cards.length;
  if (total === 0) return;

  const VISIBLE = 3;
  const PEEK = 10;
  const DURATION = 350;
  let isAnimating = false;
  let touchStartY = 0;
  let currentIndex = 0;

  function layoutCards(animate) {
    cards.forEach((card, i) => {
      const y = i * PEEK;
      card.style.transition = animate ? 'transform 0.3s ease, opacity 0.3s ease' : 'none';
      card.style.display = '';
      card.style.pointerEvents = 'none';

      if (i < VISIBLE) {
        card.style.transform = `translateY(${y}px)`;
        card.style.zIndex = VISIBLE - i;
        card.style.opacity = 1;
        if (i === 0) card.style.pointerEvents = 'auto';
      } else {
        card.style.transform = `translateY(${y}px)`;
        card.style.zIndex = 0;
        card.style.opacity = 0;
      }
    });
    footer.textContent = `${(currentIndex % total) + 1} / ${total}`;
  }

  function dismissTop() {
    if (isAnimating || total <= 1) return;
    isAnimating = true;

    const top = cards[0];

    top.style.transition = `transform ${DURATION}ms cubic-bezier(.4,0,.2,1), opacity ${DURATION * 0.85}ms ease`;
    top.style.transform = 'translateY(-80px)';
    top.style.opacity = '0';
    top.style.zIndex = '999';

    const second = cards[1];
    const third = cards[2];
    if (second) {
      second.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      second.style.transform = 'translateY(0)';
    }
    if (third) {
      third.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      third.style.transform = `translateY(${PEEK}px)`;
    }

    setTimeout(() => {
      stack.appendChild(top);
      cards = Array.from(stack.querySelectorAll('.message-card'));
      currentIndex = (currentIndex + 1) % total;

      top.style.transition = 'none';
      const lastIdx = cards.length - 1;
      top.style.transform = `translateY(${lastIdx * PEEK}px)`;
      top.style.opacity = '0';
      top.style.zIndex = '0';
      top.style.pointerEvents = 'none';

      void top.offsetHeight;
      layoutCards(true);

      setTimeout(() => {
        cards.forEach(c => c.style.transition = '');
        isAnimating = false;
      }, DURATION);
    }, DURATION);
  }

  function restoreTop() {
    if (isAnimating || total <= 1) return;
    isAnimating = true;

    const last = cards[cards.length - 1];
    const first = cards[0];
    const second = cards[1];

    if (first) {
      first.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      first.style.transform = `translateY(${PEEK}px)`;
    }
    if (second) {
      second.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
      second.style.transform = `translateY(${2 * PEEK}px)`;
    }

    const restoreY = cards.length * PEEK;
    last.style.transition = 'none';
    last.style.display = '';
    last.style.transform = `translateY(${restoreY}px)`;
    last.style.opacity = '0.5';
    last.style.zIndex = '999';
    last.style.pointerEvents = 'none';

    void last.offsetHeight;

    last.style.transition = `transform ${DURATION}ms cubic-bezier(.4,0,.2,1), opacity ${DURATION * 0.85}ms ease`;
    last.style.transform = 'translateY(0)';
    last.style.opacity = '1';

    setTimeout(() => {
      stack.insertBefore(last, stack.firstChild);
      cards = Array.from(stack.querySelectorAll('.message-card'));
      currentIndex = (currentIndex - 1 + total) % total;

      last.style.transition = 'none';
      const lastIdx = cards.length - 1;
      last.style.transform = `translateY(${lastIdx * PEEK}px)`;
      last.style.opacity = '0';
      last.style.zIndex = '0';

      void last.offsetHeight;
      layoutCards(true);

      setTimeout(() => {
        cards.forEach(c => c.style.transition = '');
        isAnimating = false;
      }, DURATION);
    }, DURATION);
  }

  stack.addEventListener('wheel', (e) => {
    e.preventDefault();
    if (e.deltaY > 0) dismissTop();
    else restoreTop();
  }, { passive: false });

  stack.addEventListener('touchstart', (e) => {
    touchStartY = e.touches[0].clientY;
  }, { passive: true });

  stack.addEventListener('touchmove', (e) => {
    e.preventDefault();
  }, { passive: false });

  stack.addEventListener('touchend', (e) => {
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (dy < -20) dismissTop();
    else if (dy > 20) restoreTop();
  }, { passive: true });

  layoutCards(false);
  setTimeout(() => cards.forEach(c => c.style.transition = ''), 50);
})();
</script>
