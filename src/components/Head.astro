---
import { SITE_INFO } from "../consts";
import Dark from "./Dark.astro";
import Search from "./Search.astro";
---
<style is:inline>
    .site-header {
        position: relative;
        height: 38vh;
        background-color: var(--surface-header-fallback);
        background-image: var(--wallpaper);
        background-repeat: no-repeat;
        background-position: center bottom 28%;
        background-size: cover;
    }
</style>
<header class="site-header" style={`--wallpaper: url('${SITE_INFO.wallpaper}')`}>
    <Dark />
    <Search />
</header>
