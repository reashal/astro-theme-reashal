<button
    type="button"
    class="reading-flight"
    aria-label="阅读进度 0%，点击飞回篇首"
    title="飞回篇首"
    data-reading-flight
>
    <span class="reading-flight-route" aria-hidden="true">
        <span class="reading-flight-trail" data-reading-flight-trail></span>
    </span>
    <span
        class="reading-flight-aircraft"
        data-reading-flight-plane
        aria-hidden="true"
    >
        <span class="reading-flight-exhaust">
            <i></i>
            <i></i>
            <i></i>
        </span>
        <svg
            class="reading-flight-plane"
            viewBox="0 0 28 32"
            focusable="false"
        >
            <path
                class="reading-flight-plane-wing"
                d="M13.86 29.53c-.18.32-.64.29-.78-.05L3.35 6.07c-.34-.82.1-1.18.91-.86l9.16 2.18c.35.08.58.4.58.76v20.69c0 .25-.05.49-.14.69Z"
            ></path>
            <path
                class="reading-flight-plane-wing reading-flight-plane-wing-far"
                d="M14.14 29.53c.18.32.64.29.78-.05l9.73-23.41c.34-.82-.1-1.18-.91-.86l-9.16 2.18a.79.79 0 0 0-.58.76v20.69c0 .25.05.49.14.69Z"
            ></path>
            <path
                class="reading-flight-plane-flap"
                d="M14 7.98 10.36 18.8 14 17.24Z"
            ></path>
            <path
                class="reading-flight-plane-fold"
                d="M14 8.08v20.64"
            ></path>
        </svg>
        <span class="reading-flight-headlights">
            <i></i>
            <i></i>
        </span>
    </span>
</button>

<style>
    .reading-flight {
        --reading-progress: 0%;

        position: fixed;
        top: 50%;
        right: .1rem;
        z-index: 998;
        width: 2.5rem;
        height: 4.75rem;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--color-brand);
        cursor: pointer;
        opacity: 0;
        pointer-events: none;
        transform: translate(.65rem, -50%);
        transition:
            opacity .25s ease,
            transform .25s ease,
            color .2s ease;
    }

    .reading-flight.is-visible {
        opacity: .82;
        pointer-events: auto;
        transform: translate(0, -50%);
    }

    .reading-flight:hover,
    .reading-flight.is-returning {
        color: var(--color-brand-hover);
        opacity: 1;
        transform: translate(-.12rem, -50%);
    }

    .reading-flight:focus-visible {
        outline: 1px solid currentColor;
        outline-offset: 1px;
        border-radius: 1.1rem;
        opacity: 1;
    }

    .reading-flight-route {
        position: absolute;
        top: .55rem;
        bottom: .55rem;
        left: 50%;
        width: 6px;
        overflow: hidden;
        border-radius: 4px;
        background-color: rgb(var(--rgb-brand) / 8%);
        box-shadow: inset 0 0 0 1px rgb(var(--rgb-brand) / 5%);
        transform: translateX(-50%);
    }

    .reading-flight-route::after {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 50%;
        width: 1px;
        background: repeating-linear-gradient(
            to bottom,
            rgb(var(--rgb-brand) / 17%) 0 2px,
            transparent 2px 6px
        );
        content: "";
        transform: translateX(-50%);
    }

    .reading-flight-trail {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: var(--reading-progress);
        background: linear-gradient(
            to bottom,
            rgb(var(--rgb-brand) / 7%),
            rgb(var(--rgb-brand) / 24%)
        );
        transition: height .08s linear;
    }

    .reading-flight-aircraft {
        position: absolute;
        top: .55rem;
        left: 50%;
        display: block;
        width: 1.85rem;
        height: 1.85rem;
        pointer-events: none;
        transform: translate(-50%, -50%);
        transform-origin: center;
        transition:
            top .08s linear,
            transform .28s ease;
    }

    .reading-flight-plane {
        position: relative;
        z-index: 1;
        display: block;
        width: 100%;
        height: 100%;
        overflow: visible;
        fill: currentColor;
        filter: drop-shadow(0 1px 3px rgb(var(--rgb-white) / 85%));
    }

    .reading-flight-plane-wing-far {
        opacity: .58;
    }

    .reading-flight-plane-flap {
        fill: rgb(var(--rgb-white) / 25%);
    }

    .reading-flight-plane-fold {
        fill: none;
        stroke: rgb(var(--rgb-white) / 46%);
        stroke-linecap: round;
        stroke-width: .75;
    }

    .reading-flight-exhaust {
        position: absolute;
        bottom: calc(100% - .32rem);
        left: 50%;
        height: .78rem;
        display: grid;
        grid-template-columns: repeat(3, 1.25px);
        gap: 2.75px;
        transform: translateX(-50%);
    }

    .reading-flight-exhaust i {
        display: block;
        height: 100%;
        background: rgb(var(--rgb-brand) / 70%);
        -webkit-mask-image: linear-gradient(
            to bottom,
            rgb(0 0 0 / 18%),
            #000
        );
        mask-image: linear-gradient(to bottom, rgb(0 0 0 / 18%), #000);
    }

    .reading-flight-exhaust i:nth-child(2) {
        background: rgb(var(--rgb-brand) / 86%);
    }

    .reading-flight-headlights {
        position: absolute;
        top: calc(100% - .22rem);
        left: 50%;
        height: .3rem;
        display: grid;
        grid-template-columns: repeat(2, 1.35px);
        gap: 5.25px;
        filter: drop-shadow(0 0 2px rgb(var(--rgb-brand) / 50%));
        transform: translateX(-50%);
    }

    .reading-flight-headlights i {
        position: relative;
        display: block;
        height: 100%;
        background: rgb(var(--rgb-brand) / 78%);
        -webkit-mask-image: linear-gradient(
            to bottom,
            #000,
            rgb(0 0 0 / 14%)
        );
        mask-image: linear-gradient(to bottom, #000, rgb(0 0 0 / 14%));
    }

    .reading-flight-headlights i::before {
        position: absolute;
        top: -1px;
        left: 50%;
        width: 2px;
        height: 2px;
        border-radius: 50%;
        background: rgb(var(--rgb-white) / 82%);
        content: "";
        transform: translateX(-50%);
    }

    .reading-flight:hover .reading-flight-aircraft {
        transform: translate(-50%, -50%) rotate(180deg) scale(1.06);
    }

    .reading-flight.is-returning .reading-flight-aircraft {
        transform: translate(-50%, -50%) rotate(180deg);
    }

    :global(.dark) .reading-flight {
        color: var(--color-accent-cyan);
    }

    :global(.dark) .reading-flight:hover,
    :global(.dark) .reading-flight.is-returning {
        color: var(--color-accent-cyan-hover);
    }

    :global(.dark) .reading-flight-route {
        background-color: rgb(var(--rgb-accent-cyan) / 9%);
        box-shadow: inset 0 0 0 1px rgb(var(--rgb-accent-cyan) / 6%);
    }

    :global(.dark) .reading-flight-route::after {
        background: repeating-linear-gradient(
            to bottom,
            rgb(var(--rgb-accent-cyan) / 19%) 0 2px,
            transparent 2px 6px
        );
    }

    :global(.dark) .reading-flight-trail {
        background: linear-gradient(
            to bottom,
            rgb(var(--rgb-accent-cyan) / 8%),
            rgb(var(--rgb-accent-cyan) / 27%)
        );
    }

    :global(.dark) .reading-flight-exhaust i {
        background: rgb(var(--rgb-accent-cyan) / 82%);
    }

    :global(.dark) .reading-flight-exhaust i:nth-child(2) {
        background: rgb(var(--rgb-accent-cyan) / 96%);
    }

    :global(.dark) .reading-flight-headlights i {
        background: rgb(var(--rgb-accent-cyan) / 92%);
    }

    :global(.dark) .reading-flight-headlights {
        filter: drop-shadow(0 0 2px rgb(var(--rgb-accent-cyan) / 72%));
    }

    :global(.dark) .reading-flight-plane {
        filter: drop-shadow(0 2px 4px rgb(var(--rgb-black) / 58%));
    }

    @media screen and (max-width: 488px) {
        .reading-flight {
            right: 0;
            width: 2.3rem;
            height: 4.4rem;
        }

        .reading-flight-plane {
            width: 100%;
            height: 100%;
        }

        .reading-flight-aircraft {
            width: 1.65rem;
            height: 1.65rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .reading-flight,
        .reading-flight-trail,
        .reading-flight-aircraft {
            transition: none;
        }
    }
</style>

<script>
    const readingFlight = document.querySelector<HTMLButtonElement>(
        "[data-reading-flight]",
    );
    const flightTrail = document.querySelector<HTMLElement>(
        "[data-reading-flight-trail]",
    );
    const flightRoute = flightTrail?.parentElement;
    const flightPlane = document.querySelector<HTMLElement>(
        "[data-reading-flight-plane]",
    );
    const scrollContainer = document.querySelector<HTMLElement>(".main");
    const article = document.querySelector<HTMLElement>(
        ".article-container.doc",
    );

    if (
        readingFlight &&
        flightRoute &&
        flightTrail &&
        flightPlane &&
        scrollContainer
    ) {
        let animationFrame = 0;

        const updateReadingFlight = () => {
            animationFrame = 0;
            const scrollableDistance =
                scrollContainer.scrollHeight - scrollContainer.clientHeight;
            const progress =
                scrollableDistance > 0
                    ? Math.min(
                          100,
                          Math.max(
                              0,
                              (scrollContainer.scrollTop /
                                  scrollableDistance) *
                                  100,
                          ),
                      )
                    : 0;
            const roundedProgress = Math.round(progress);

            readingFlight.style.setProperty(
                "--reading-progress",
                `${progress}%`,
            );
            flightPlane.style.top = `${
                flightRoute.offsetTop +
                (progress / 100) * flightRoute.offsetHeight
            }px`;
            readingFlight.classList.toggle(
                "is-visible",
                scrollableDistance > 0 && scrollContainer.scrollTop > 48,
            );
            if (scrollContainer.scrollTop <= 1) {
                readingFlight.classList.remove("is-returning");
            }
            readingFlight.setAttribute(
                "aria-label",
                `阅读进度 ${roundedProgress}%，点击飞回篇首`,
            );
        };

        const requestFlightUpdate = () => {
            if (animationFrame) return;
            animationFrame = requestAnimationFrame(updateReadingFlight);
        };

        readingFlight.addEventListener("click", () => {
            const reduceMotion = window.matchMedia(
                "(prefers-reduced-motion: reduce)",
            ).matches;
            readingFlight.classList.add("is-returning");
            readingFlight.blur();
            scrollContainer.scrollTo({
                top: 0,
                behavior: reduceMotion ? "auto" : "smooth",
            });
        });

        scrollContainer.addEventListener("scroll", requestFlightUpdate, {
            passive: true,
        });
        window.addEventListener("resize", requestFlightUpdate);
        window.addEventListener("load", requestFlightUpdate);

        const resizeObserver = new ResizeObserver(requestFlightUpdate);
        resizeObserver.observe(scrollContainer);
        if (article) resizeObserver.observe(article);

        updateReadingFlight();
    }
</script>
